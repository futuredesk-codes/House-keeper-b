# HOUSEKER backend environment
NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/houseker

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# File storage (local disk for dev; swap for S3/GCS in prod)
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./storage
# HMAC secret for signing time-limited download/preview URLs
FILE_SIGNING_SECRET=change-me-file-signing-secret
SIGNED_URL_TTL_SECONDS=300

# CORS - admin panel origin
ADMIN_ORIGIN=http://localhost:5173

# Seed super admin (used by npm run seed)
SEED_ADMIN_NAME=Super Admin
SEED_ADMIN_EMAIL=admin@houseker.com
SEED_ADMIN_PASSWORD=Admin@12345
